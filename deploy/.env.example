# Docker Compose customization

# Signed log and witness checkpoint origins. Change these before generating keys
# for a non-example deployment.
LOG_ORIGIN=binarytransparency.log/example
WITNESS_ORIGIN=witness.log/example

# Host ports exposed by docker compose. bt-log and witness are bound to
# 127.0.0.1 so they are only directly reachable from the host.
BT_LOG_PORT=8080
WITNESS_PORT=8081

# Bulk append tuning for /admin/bulk/append.
BT_LOG_BULK_APPEND_WORKERS=8192
BT_LOG_BULK_APPEND_MAX_ENTRIES=50000
BT_LOG_BULK_APPEND_PUBLISH_TIMEOUT=30s

# Optional read-only proxy for public exposure. Expose this port with Tailscale
# Funnel instead of exposing BT_LOG_PORT directly.
READONLY_PROXY_PORT=8088

# Internal Docker upstream for the read-only proxy. Use bt-log-mysql:8080 or
# bt-log-postgres:8080 if running those profiles instead of sqlite.
BT_LOG_UPSTREAM=bt-log-sqlite:8080
